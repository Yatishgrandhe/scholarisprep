{
  "crons": [
    {
      "path": "/api/admin/pregenerate-questions",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:svg|png|ico|jpg|jpeg|gif|webp|avif|woff|woff2))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
