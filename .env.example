# =============================================================================
# Scholaris — copy to .env.local and fill in values
# =============================================================================
# Build fails with a descriptive error if any "Required at build" variable is
# empty. Validation runs from next.config.ts via src/lib/env.validate.ts.
# =============================================================================

# --- Required at build: Supabase (Auth + database) ---
# Used by: src/lib/supabase/client.ts, server.ts, middleware.ts, admin.ts
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required at build (server-only). Used by: src/lib/supabase/admin.ts,
# src/app/api/account/delete/route.ts, src/app/api/stripe/webhook/route.ts,
# src/lib/stripe/upsert-subscription.ts, src/lib/admin/require-platform-admin.ts,
# src/app/api/org/invite/route.ts, src/app/api/email/welcome/route.ts,
# src/lib/auth/welcome-email.ts
SUPABASE_SERVICE_ROLE_KEY=

# --- Required at build: Google Gemini (tutor, AI routes, course generation) ---
# Used by: src/lib/gemini.ts → src/app/api/ai/*, src/lib/courses/ai-lesson.ts,
# src/lib/geminiPool.ts (round-robin pool for batch question generation),
# src/lib/env.ts (isGeminiConfigured), src/app/api/ai/tutor/route.ts
# https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=
# Optional pool keys for higher throughput / 429 failover (used by geminiPool.ts)
GOOGLE_GEMINI_API_KEY_1=
GOOGLE_GEMINI_API_KEY_2=
GOOGLE_GEMINI_API_KEY_3=
GOOGLE_GEMINI_API_KEY_4=
GOOGLE_GEMINI_API_KEY_5=

# --- Optional: Vercel Cron auth for /api/admin/pregenerate-questions ---
# Vercel sends Authorization: Bearer <CRON_SECRET> when set in project env.
# x-vercel-cron: 1 is also accepted when deployed on Vercel.
CRON_SECRET=

# --- App URL (OAuth redirects, Stripe return URLs, emails) ---
# Used by: src/lib/env.ts (getAppUrl), src/emails/brand.ts,
# src/app/api/stripe/checkout|portal/route.ts, src/lib/email/send.ts,
# src/app/api/org/invite/route.ts, src/components/auth/SignupForm.tsx
# Optional at build; defaults to http://localhost:3000 or VERCEL_URL on Vercel
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Required at build: Resend (transactional email) ---
# Used by: src/lib/resend.ts, src/lib/email/send.ts, src/lib/env.ts,
# src/lib/auth/welcome-email.ts, admin/org invite & moderation emails.
# Password reset does NOT use Resend — it goes through Supabase Auth email
# (resetPasswordForEmail → Auth SMTP / Custom SMTP).
# https://resend.com/api-keys — verify your sending domain in Resend first.
# Must be a real key (re_<long opaque string>). The placeholder `re_...` is
# rejected by isResendConfigured().
RESEND_API_KEY=
# Used by: src/lib/env.ts (getResendFromAddress), src/lib/resend.ts
# Domain in this address must be verified in Resend (or use onboarding@resend.dev for tests).
RESEND_FROM_EMAIL=Scholaris <hello@scholaris.ai>

# Password reset (Supabase Auth):
# Dashboard → Authentication → URL Configuration — Site URL = production origin
# (e.g. https://finalse.us). Redirect allowlist must include:
#   {NEXT_PUBLIC_APP_URL}/auth/callback
#   {NEXT_PUBLIC_APP_URL}/auth/callback?next=/auth/reset-password
#   {NEXT_PUBLIC_APP_URL}/auth/confirm
#   {NEXT_PUBLIC_APP_URL}/auth/reset-password
# Dashboard → Authentication → Emails → Reset password template (SSR-friendly):
#   {{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=recovery&next=/auth/reset-password
# Dashboard → Authentication → SMTP: use Custom SMTP in production (built-in
# Auth email is rate-limited / best-effort). Same SMTP sends signup + recovery.

# --- Required at build: Stripe (payments & subscriptions) ---
# Used by: src/lib/stripe.ts
STRIPE_SECRET_KEY=sk_test_...
# Used by: (client checkout UI when wired); validated at build for production readiness
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Used by: src/app/api/stripe/webhook/route.ts, src/lib/stripe/webhook.ts
# Endpoint URL: {NEXT_PUBLIC_APP_URL}/api/stripe/webhook
# Enable events: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
# Local testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — required for checkout; not validated at build
# Used by: src/lib/stripe/prices.ts, src/app/api/stripe/checkout/route.ts
# Create in Stripe Dashboard or run: scripts/create-stripe-products.sh
STRIPE_PRICE_STUDENT_MONTHLY=price_...
STRIPE_PRICE_STUDENT_ANNUAL=price_...
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_BUSINESS=price_...

# --- Required at build: YouTube Data API (course import from playlists) ---
# Used by: src/app/api/youtube/playlist/route.ts,
# src/app/api/ai/generate-course/route.ts
# Google Cloud Console → enable YouTube Data API v3 → API key
YOUTUBE_API_KEY=

# --- Optional: platform shared AI key (server-only env fallback) ---
# Preferred path: paste the key in /admin/ai-key-policy (stored in app_secrets).
# Env is used only when the DB secret is empty. Used by keyPolicy.resolveAiClient
# when mode is `global` (central) or `platform_only`. Prefer MISTRAL_SHARED_API_KEY;
# MISTRAL_API_KEY is a fallback alias. NEVER set NEXT_PUBLIC_* for this.
# Central mode uses FreeModel (https://cc.freemodel.dev) + Claude Sonnet — not Mistral.
# Optional overrides: AI_API_BASE_URL, AI_API_MODEL (defaults in app_settings).
# Default policy is `personal` (BYO Mistral). Set mode to `global` in admin UI for central.
MISTRAL_SHARED_API_KEY=
# MISTRAL_API_KEY=
# AI_API_BASE_URL=https://cc.freemodel.dev
# AI_API_MODEL=claude-sonnet-4-6

# --- Optional: Tavily web search (Ask Scho tutor "search online" tool) ---
# Used by: src/lib/ai/webSearch.ts (via src/lib/ai/tools.ts → web_search tool).
# When set, the tutor's web_search uses Tavily (cleaner, LLM-ranked results).
# When unset, it falls back to a keyless DuckDuckGo scrape — no account needed.
# Free tier: https://tavily.com
TAVILY_API_KEY=

# --- Optional: server-to-server welcome email endpoint ---
# Used by: src/app/api/email/welcome/route.ts
EMAIL_WEBHOOK_SECRET=

# --- Optional: Desmos calculator (math practice & exams) ---
# Used by: src/lib/desmos/loadDesmos.ts, src/components/calculator/DesmosCalculator.tsx
# Optional: if unset the app falls back to Desmos's public demo key so the
# calculator still works. Set your own free key for production (per-domain).
# Free personal key: https://www.desmos.com/api — commercial/production: partners@desmos.com
NEXT_PUBLIC_DESMOS_API_KEY=

# --- Optional: Cloudflare R2 (Free Studying note images) ---
# Used by: src/lib/storage/r2.ts, src/app/api/notes/images/*
# Endpoint is derived as https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# Graceful when unset — image upload APIs return 503 with a clear message.
# Dashboard: Cloudflare → R2 → bucket + S3 API token (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Optional: marketing / auth imagery ---
# NEXT_PUBLIC_UNSPLASH_ACCESS_KEY — reserved; src/lib/unsplash.ts uses static URLs
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=
# NEXT_PUBLIC_APP_NAME — reserved for branding strings
NEXT_PUBLIC_APP_NAME=Scholaris
